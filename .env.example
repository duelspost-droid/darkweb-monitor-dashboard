# ── 유출 모니터링 데이터 소스 ─────────────────────────────────────────────
# (A) 무료: 키 불필요. 모니터링할 회사 계정 이메일을 monitor_config.local.json
#     의 accounts 에 넣으면 XposedOrNot 로 계정별 유출을 조회한다(기본 경로).
#
# (B) 유료: Have I Been Pwned 도메인 검색(도메인 전수). 키 설정 시 자동 우선.
#     발급 https://haveibeenpwned.com/API/Key + HIBP 대시보드 도메인 소유 검증.
#     ★ 임직원 이메일 "전수" 모니터링은 명부 없이 이 도메인 검색으로 달성한다.
HIBP_API_KEY=

# (C) 보조 소스 — 키 있으면 사용, 없으면 조용히 skip(기존 소스 유지). 모두 breach_findings 로 매핑.
#   Intelligence X (도메인 전수 유출 레코드). 발급 https://intelx.io (x-key).
INTELX_API_KEY=
INTELX_API_HOST=          # 기본 https://2.intelx.io (계정별 전용 호스트면 지정)
INTELX_BUCKETS=           # 쉼표구분 버킷 제한(크레딧 절약, 선택)
#   LeakCheck. 키 있으면 Pro v2 type=domain(도메인 전수, 평문 password 는 저장 안 함);
#   없으면 무료 public(?check=) 으로 accounts(계정별)만 조회. 발급 https://leakcheck.io
LEAKCHECK_API_KEY=
# (D) Hudson Rock Cavalier 무료 OSINT(계정별 search-by-email 등). 키 불필요.
#     끄려면 0. 기본 켜짐(accounts 가 있을 때만 계정별 조회).
HUDSONROCK_OSINT_ENABLED=1
# (E) GitHub 공개 노출 검색 — 공개 코드/gist 에서 도메인+자격증명 노출 탐지(무료·합법, 명부 불필요).
#     GitHub Personal Access Token (public repo 읽기면 충분). 발급 github.com/settings/tokens
#     키 있으면 사용, 없으면 skip. 자격증명 값은 저장 안 하고 repo/파일/URL 포인터만 적재.
GITHUB_TOKEN=

# ── Supabase 백엔드 ────────────────────────────────────────────────────────
# 배치(Edge Function/스크립트)용 — service_role 은 절대 클라이언트 노출 금지.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 빌드 시 Supabase→정적사이트 pull 및 (선택) 클라이언트 읽기용 anon 키.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 고정 관리자 계정 이메일. 설정 시 로그인 폼이 비밀번호만 받고 이 계정으로 인증한다.
# (Supabase Auth 는 식별자가 필수 → 클라이언트 번들에 노출되지만 게이트는 비밀번호.)
NEXT_PUBLIC_ADMIN_EMAIL=

# ── Edge Function Secrets (supabase secrets set 으로 등록) ─────────────────
# 무료 경로: 모니터링 대상 이메일(쉼표구분). DB엔 마스킹만 저장됨.
MONITORED_EMAILS=
# 유료 경로(HIBP): 도메인(쉼표구분).
MONITORED_DOMAINS=
# 위 (C)/(D) 보조 소스 키도 동일하게 Edge 시크릿으로 등록하면 자정 배치에 적용된다:
#   supabase secrets set INTELX_API_KEY=... LEAKCHECK_API_KEY=... HUDSONROCK_OSINT_ENABLED=1
